// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection – only owners can read/write their own profile
    match /users/{userId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.token.role == 'admin';
    }
    // Teams – organizers can create, admins can read/write all, participants can read their own team
    match /teams/{teamId} {
      allow read: if request.auth != null;
      allow create: if request.auth.token.role in ['admin', 'organizer'];
      allow update, delete: if request.auth.token.role == 'admin' || (request.auth.token.role == 'organizer' && resource.data.leaderUid == request.auth.uid);
    }
    // Projects – read for all signed‑in users, write for admin/organizer
    match /projects/{projectId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.role in ['admin', 'organizer'];
    }
    // Announcements – read for anyone, write for admin
    match /announcements/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == 'admin';
    }
    // Resources – read for anyone, write for admin
    match /resources/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == 'admin';
    }
    // Documents (uploaded KB files) – read for signed‑in users, write for admin
    match /documents/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.token.role == 'admin';
    }
  }
}
function isSignedIn() { return request.auth != null; }
