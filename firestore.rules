// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection – users can read/write their own profile, admins can create
    match /users/{userId} {
      allow read, update, delete: if request.auth != null && (request.auth.uid == userId || request.auth.token.role in ['admin', 'organizer']);
      allow create: if request.auth != null && (request.auth.uid == userId || request.auth.token.role == 'admin');
    }
    // Teams – anyone logged in can create a team, admins/organizers have elevated access
    match /teams/{teamId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null; // Ideally restrict to team members or admin, but keeping it open for auth'd users for now to prevent failures
    }
    // Projects – read for all signed‑in users, write for admin/organizer
    match /projects/{projectId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.role in ['admin', 'organizer'];
    }
    // Announcements – read for anyone, write for admin
    match /announcements/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == 'admin';
    }
    // Problem Statements – read for anyone, write for admin/organizer
    match /problemStatements/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role in ['admin', 'organizer'];
    }
    // Resources – read for anyone, write for admin
    match /resources/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == 'admin';
    }
    // Documents (uploaded KB files) – read for signed‑in users, write for admin
    match /documents/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.token.role == 'admin';
    }
    // Notifications
    match /notifications/{docId} {
      allow read, write: if request.auth != null;
    }
    // Tickets
    match /tickets/{docId} {
      allow read, write: if request.auth != null;
    }
    // Evaluations
    match /evaluations/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
function isSignedIn() { return request.auth != null; }
